# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
NOTIFICATION_CHANNEL_ID=your_channel_id_here
GUILD_ID=your_guild_id_here

# TMDb API
TMDB_API_KEY=your_tmdb_api_key_here

# Media Library (comma-separated for multiple paths)
MEDIA_PATHS=/Volumes/Media/Movies,/Volumes/Media/TV Shows

# Optional
LOG_LEVEL=INFO
SCAN_INTERVAL_MINUTES=60

# eBay API (optional — enables Blu-ray deal searching)
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here

# Upgrade Scanner
UPGRADE_SCAN_INTERVAL_HOURS=24
UPGRADE_CHANNEL_ID=your_upgrade_channel_id_here
# MAX_EBAY_PRICE=20

# OpenSubtitles (optional — enables subtitle downloading)
OPENSUBTITLES_API_KEY=your_api_key_here
OPENSUBTITLES_USERNAME=your_username_here
OPENSUBTITLES_PASSWORD=your_password_here
